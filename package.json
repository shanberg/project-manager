{
  "name": "project-manager",
  "version": "0.1.0",
  "description": "CLI for PARA-style project creation with domain-based numbering",
  "type": "module",
  "main": "dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./types": "./dist/types.js",
    "./notes": "./dist/lib/notes/index.js"
  },
  "bin": {
    "pm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "para",
    "projects"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@shanberg/project-schema": "file:../project-schema",
    "commander": "^11.1.0"
  }
}
