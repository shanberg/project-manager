{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@shanberg/project-schema": ["./node_modules/@shanberg/project-schema"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
