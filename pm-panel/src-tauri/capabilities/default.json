{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "window-state:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "shell:default",
    "fs:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "pm-notes-show",
          "cmd": "pm",
          "args": [
            "notes",
            "show",
            {
              "validator": ".+"
            }
          ]
        }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$HOME/.config/pm/*"
        }
      ]
    }
  ]
}