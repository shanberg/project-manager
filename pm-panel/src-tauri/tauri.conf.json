{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PM Panel",
  "version": "0.1.0",
  "identifier": "com.stuarthanberg.pm-panel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "PM Panel",
        "label": "main",
        "width": 380,
        "minWidth": 380,
        "maxWidth": 380,
        "height": 420,
        "visible": false,
        "alwaysOnTop": true,
        "resizable": true,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "title": "PM Panel",
        "label": "shade",
        "width": 800,
        "height": 420,
        "visible": false,
        "alwaysOnTop": true,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}